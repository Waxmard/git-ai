#!/bin/bash
set -o pipefail
# ai-provider-menu - Output providers ordered by last-used for LazyGit menus
# Usage: ai-provider-menu <tool-name>

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
# shellcheck source=lib/ai-common.sh
source "${SCRIPT_DIR}/../lib/ai-common.sh"

TOOL_NAME="${1:-ai-commit-gen}"

display_name() {
  case $1 in
    codex)  echo "OpenAI (Codex)" ;;
    gemini) echo "Gemini" ;;
    claude) echo "Claude" ;;
  esac
}

last=$(get_last_provider "$TOOL_NAME")
all=(claude gemini codex)
ordered=("$last")
for p in "${all[@]}"; do
  [[ "$p" != "$last" ]] && ordered+=("$p")
done

for p in "${ordered[@]}"; do
  printf '%s|%s\n' "$p" "$(display_name "$p")"
done
