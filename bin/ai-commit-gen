#!/bin/bash
set -o pipefail
# ai-commit-gen - Generate commit messages using Claude, Gemini, or Codex
# Usage: ai-commit-gen [claude|gemini|codex]

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "${SCRIPT_DIR}/../lib/ai-common.sh"

PROVIDER=${1:-claude}
PROMPT="Generate 1 git commit message using Conventional Commits format (feat:, fix:, refactor:, build:, chore:, docs:, style:, test:, perf:, ci:). Output ONLY the commit message on a single line. Include a description body separated by a blank line for non-trivial changes. No numbering, no bullets, no explanations. Do not wrap in code blocks or backticks."

git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"
git diff --staged --quiet && die "no staged changes to summarize"

STAGED_DIFF=$(git diff --staged) || die "failed to read staged diff"

run_provider "$PROVIDER" "$PROMPT" "$STAGED_DIFF"
