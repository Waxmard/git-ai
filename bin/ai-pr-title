#!/bin/bash
set -o pipefail
# ai-pr-title - Generate PR titles and bodies using Claude, Gemini, or Codex
# Usage: ai-pr-title [claude|gemini|codex] [tier] [--base <branch>]

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
# shellcheck source=lib/ai-common.sh
source "${SCRIPT_DIR}/../lib/ai-common.sh"

PROVIDER=$(get_last_provider ai-pr-title)
MODEL_TIER=""
BASE=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --base)
      BASE="$2"
      shift 2
      ;;
    claude|gemini|codex)
      PROVIDER="$1"
      shift
      case "${1:-}" in
        haiku|sonnet|opus|flash-lite|pro|mini|standard)
          MODEL_TIER="$1"
          shift
          ;;
      esac
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

PROMPT="Generate a pull request title and body. The title MUST use Conventional Commits format (feat:, fix:, refactor:, build:, chore:, docs:, style:, test:, perf:, ci:) on a single line. Use ! (e.g. feat!:) ONLY for changes that break backward compatibility — removed or renamed public interface, changed required arguments, or incompatible behavior change. When in doubt, omit !. Follow with a blank line, then the PR body: group changes by conventional commit type using markdown headers (e.g. ### Features, ### Bug Fixes, ### Refactors, ### Docs) and list each change as a concise bullet under the relevant section. Only include sections that have changes. Output ONLY the title and body. Do not wrap in code blocks or backticks."

git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"

if [[ -z "$BASE" ]]; then
  BASE=$(git remote show origin 2>/dev/null | sed -n 's/.*HEAD branch: //p')
  BASE=${BASE:-main}
fi

LOG=$(git log --oneline "$BASE"..HEAD 2>/dev/null) || die "failed to read commit log against $BASE"
[[ -z "$LOG" ]] && die "no commits ahead of $BASE"

DIFF=$(git diff "$BASE"...HEAD 2>/dev/null) || die "failed to read diff against $BASE"

INPUT="Commit log:
$LOG

Diff:
$DIFF"

run_provider ai-pr-title "$PROVIDER" "$PROMPT" "$INPUT" "$MODEL_TIER"
