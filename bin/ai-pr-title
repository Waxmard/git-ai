#!/bin/bash
set -o pipefail
# ai-pr-title - Generate PR titles and bodies using Claude, Gemini, or Codex
# Usage: ai-pr-title [claude|gemini|codex] [tier] [--base <branch>] [--fresh]
# Recommended tiers: claude sonnet/opus, gemini pro — weaker tiers (haiku, flash-lite)
# may not follow grouping instructions reliably.

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
# shellcheck source=lib/ai-common.sh
source "${SCRIPT_DIR}/../lib/ai-common.sh"

PROVIDER=$(get_last_provider ai-pr-title)
MODEL_TIER=""
BASE=""
FRESH=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --base)
      BASE="$2"
      shift 2
      ;;
    --fresh)
      FRESH=true
      shift
      ;;
    claude|gemini|codex)
      PROVIDER="$1"
      shift
      case "${1:-}" in
        haiku|sonnet|opus|flash-lite|pro|mini|standard)
          MODEL_TIER="$1"
          shift
          ;;
      esac
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

PROMPT_TWO_PASS="Given an auto-generated PR body draft (grouped from conventional commit messages) and a list of changed files, write a polished PR title in Conventional Commits format (feat:, fix:, refactor:, build:, chore:, docs:, style:, test:, perf:, ci:) on a single line and a refined body. Use ! (e.g. feat!:) ONLY for changes that break backward compatibility — removed or renamed public interface, changed required arguments, or incompatible behavior change. When in doubt, omit !. If the renamed or removed interface was introduced after the last tag (i.e., it appears in this PR's changes but was not present at the last release), it has never shipped to consumers and cannot be a breaking change — omit !. Keep the same section groupings from the draft (e.g. ### Features, ### Bug Fixes, ### Refactors, ### Docs). Only include sections that have changes. Some entries in the draft may be intra-branch churn (fixes or refactors of code introduced in this same PR) — consolidate or remove these rather than listing them as separate sections. Focus on the net, final effect of the PR relative to the base branch. Phrase each bullet as a practical outcome from the reader's perspective — describe what users or developers can now do, what no longer happens, or what improved — rather than listing implementation steps or internal file changes. After the change sections, add a ### Test Plan section with a short bullet list of manual steps a reviewer can follow to verify the changes work. Output ONLY the title and body. Do not wrap in code blocks or backticks."

PROMPT_FALLBACK="Generate a pull request title and body. The title MUST use Conventional Commits format (feat:, fix:, refactor:, build:, chore:, docs:, style:, test:, perf:, ci:) on a single line. Use ! (e.g. feat!:) ONLY for changes that break backward compatibility — removed or renamed public interface, changed required arguments, or incompatible behavior change. When in doubt, omit !. If the renamed or removed interface was introduced after the last tag (i.e., it appears in this PR's changes but was not present at the last release), it has never shipped to consumers and cannot be a breaking change — omit !. Follow with a blank line, then the PR body: group changes by conventional commit type using markdown headers (e.g. ### Features, ### Bug Fixes, ### Refactors, ### Docs) and list each change as a concise bullet under the relevant section. Only include sections that have changes. Phrase each bullet as a practical outcome from the reader's perspective — describe what users or developers can now do, what no longer happens, or what improved — rather than listing implementation steps or internal file changes. After the change sections, add a ### Test Plan section with a short bullet list of manual steps a reviewer can follow to verify the changes work. Output ONLY the title and body. Do not wrap in code blocks or backticks."

PROMPT_TWO_PASS_UPDATE="An existing PR title and body are provided, along with an auto-generated draft of the new commits (grouped from conventional commit messages) and a list of changed files. Update the PR title and body to incorporate the new commits while preserving the overall intent and structure of the existing description. Write a polished PR title in Conventional Commits format (feat:, fix:, refactor:, build:, chore:, docs:, style:, test:, perf:, ci:) on a single line and a refined body. Use ! (e.g. feat!:) ONLY for changes that break backward compatibility — removed or renamed public interface, changed required arguments, or incompatible behavior change. When in doubt, omit !. If the renamed or removed interface was introduced after the last tag (i.e., it appears in this PR's changes but was not present at the last release), it has never shipped to consumers and cannot be a breaking change — omit !. Keep the same section groupings (e.g. ### Features, ### Bug Fixes, ### Refactors, ### Docs). Only include sections that have changes. Some entries may be intra-branch churn (fixes or refactors of code introduced in this same PR) — consolidate or remove these rather than listing them as separate sections. Focus on the net, final effect of the PR relative to the base branch. Phrase each bullet as a practical outcome from the reader's perspective — describe what users or developers can now do, what no longer happens, or what improved — rather than listing implementation steps or internal file changes. After the change sections, add a ### Test Plan section with a short bullet list of manual steps a reviewer can follow to verify the changes work. Output ONLY the title and body. Do not wrap in code blocks or backticks."

PROMPT_FALLBACK_UPDATE="An existing PR title and body are provided, along with the full commit log, changed files, and diff for the current branch. Update the PR title and body to incorporate any new commits while preserving the overall intent and structure of the existing description. The title MUST use Conventional Commits format (feat:, fix:, refactor:, build:, chore:, docs:, style:, test:, perf:, ci:) on a single line. Use ! (e.g. feat!:) ONLY for changes that break backward compatibility — removed or renamed public interface, changed required arguments, or incompatible behavior change. When in doubt, omit !. If the renamed or removed interface was introduced after the last tag (i.e., it appears in this PR's changes but was not present at the last release), it has never shipped to consumers and cannot be a breaking change — omit !. Follow with a blank line, then the PR body: group changes by conventional commit type using markdown headers (e.g. ### Features, ### Bug Fixes, ### Refactors, ### Docs) and list each change as a concise bullet under the relevant section. Only include sections that have changes. Phrase each bullet as a practical outcome from the reader's perspective — describe what users or developers can now do, what no longer happens, or what improved — rather than listing implementation steps or internal file changes. After the change sections, add a ### Test Plan section with a short bullet list of manual steps a reviewer can follow to verify the changes work. Output ONLY the title and body. Do not wrap in code blocks or backticks."

current_branch_name() {
  local branch
  branch=$(git branch --show-current 2>/dev/null) || return 1
  [[ -n "$branch" ]] || return 1
  printf '%s\n' "$branch"
}

branch_cache_path() {
  local git_dir="$1"
  local branch_name="$2"
  printf '%s\n' "${git_dir}/ai-pr-title-cache/${branch_name}/last-output"
}

load_cached_pr() {
  local git_dir="$1"
  local branch_name="$2"
  local cache_file
  cache_file=$(branch_cache_path "$git_dir" "$branch_name")
  [[ -r "$cache_file" ]] || return 1
  cat "$cache_file"
}

save_cached_pr() {
  local git_dir="$1"
  local branch_name="$2"
  local output="$3"
  local cache_file cache_dir

  cache_file=$(branch_cache_path "$git_dir" "$branch_name")
  cache_dir=$(dirname "$cache_file")
  mkdir -p "$cache_dir" || return 1
  printf '%s\n' "$output" >"$cache_file"
}

git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"
GIT_DIR=$(git rev-parse --git-dir)

CURRENT_BRANCH=""
if CURRENT_BRANCH=$(current_branch_name); then
  :
fi

if [[ -z "$BASE" ]]; then
  BASE=$(git remote show origin 2>/dev/null | sed -n 's/.*HEAD branch: //p')
  BASE=${BASE:-main}
fi

# Each commit prefixed with GITAI_COMMIT to distinguish subjects from body lines
LOG=$(git log --format="GITAI_COMMIT %s%n%b" "$BASE"..HEAD 2>/dev/null) || die "failed to read commit log against $BASE"
[[ -z "$LOG" ]] && die "no commits ahead of $BASE"

DIFF_STAT=$(git diff --stat "$BASE"...HEAD 2>/dev/null) || die "failed to read diff stat against $BASE"

# Count how many commits follow conventional commit format (subject lines only)
CONVENTIONAL_COUNT=0
TOTAL_COUNT=0
while IFS= read -r line; do
  [[ "$line" == "GITAI_COMMIT "* ]] || continue
  msg="${line#GITAI_COMMIT }"
  type=$(printf '%s' "$msg" | sed 's/[!(].*//' | sed 's/:.*//')
  TOTAL_COUNT=$((TOTAL_COUNT + 1))
  case "$type" in
    feat|fix|refactor|docs|chore|ci|test|style|perf|build)
      CONVENTIONAL_COUNT=$((CONVENTIONAL_COUNT + 1)) ;;
  esac
done <<< "$LOG"

if (( TOTAL_COUNT > 0 && CONVENTIONAL_COUNT * 2 >= TOTAL_COUNT )); then
  # Two-pass: auto-draft from commit messages, LLM polishes (no diff sent)

  # Collect commits of a given type into a section; body lines indented under bullet
  draft_section() {
    local header="$1"
    local type="$2"
    local lines=""
    local capturing=false

    while IFS= read -r line; do
      if [[ "$line" == "GITAI_COMMIT "* ]]; then
        capturing=false
        msg="${line#GITAI_COMMIT }"
        t=$(printf '%s' "$msg" | sed 's/[!(].*//' | sed 's/:.*//')
        if [[ "$t" == "$type" ]]; then
          desc="${msg#*: }"
          lines+="- ${desc}"$'\n'
          capturing=true
        fi
      elif [[ "$capturing" == true && -n "$line" ]]; then
        lines+="  ${line}"$'\n'
      fi
    done <<< "$LOG"

    [[ -n "$lines" ]] && printf '### %s\n%s' "$header" "$lines"
  }

  DRAFT_BODY=""
  for args in "Features feat" "Bug Fixes fix" "Refactors refactor" "Docs docs" \
              "Chores chore" "Continuous Integration ci" "Tests test" \
              "Style style" "Performance perf" "Build build"; do
    header="${args% *}"
    type="${args##* }"
    section=$(draft_section "$header" "$type")
    [[ -n "$section" ]] && DRAFT_BODY+="${section}"$'\n\n'
  done

  PROMPT="$PROMPT_TWO_PASS"
  INPUT="Auto-generated draft (grouped from conventional commit messages):
$DRAFT_BODY
Changed files:
$DIFF_STAT"

else
  # Fallback: commits don't consistently use conventional format — pass diff directly
  DIFF=$(git diff -U0 "$BASE"...HEAD 2>/dev/null) || die "failed to read diff against $BASE"
  PROMPT="$PROMPT_FALLBACK"
  # Strip GITAI_COMMIT prefix so the LLM sees a clean commit log
  INPUT="Commit log:
$(printf '%s\n' "$LOG" | sed 's/^GITAI_COMMIT //')

Changed files:
$DIFF_STAT

Diff:
$DIFF"
fi

if [[ "$FRESH" != "true" && -n "$CURRENT_BRANCH" ]]; then
  EXISTING=$(load_cached_pr "$GIT_DIR" "$CURRENT_BRANCH" || true)
fi

if [[ -n "${EXISTING:-}" ]]; then
  INPUT="Existing PR title and body:
${EXISTING}

---

${INPUT}"
  if (( TOTAL_COUNT > 0 && CONVENTIONAL_COUNT * 2 >= TOTAL_COUNT )); then
    PROMPT="$PROMPT_TWO_PASS_UPDATE"
  else
    PROMPT="$PROMPT_FALLBACK_UPDATE"
  fi
fi

LAST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
if [[ -n "$LAST_TAG" ]]; then
  COMMITS_SINCE=$(git rev-list --count "${LAST_TAG}..HEAD" 2>/dev/null || echo "?")
  RELEASE_CONTEXT="[Release context: last tag ${LAST_TAG}, ${COMMITS_SINCE} commits since — changes in this PR are unreleased]"
else
  RELEASE_CONTEXT="[Release context: no release tags found — treat all changes as unreleased]"
fi
INPUT="${RELEASE_CONTEXT}"$'\n\n'"${INPUT}"

OUTPUT=$(run_provider ai-pr-title "$PROVIDER" "$PROMPT" "$INPUT" "$MODEL_TIER") || exit $?
save_last_message ai-pr-title "$OUTPUT"
if [[ -n "$CURRENT_BRANCH" ]]; then
  save_cached_pr "$GIT_DIR" "$CURRENT_BRANCH" "$OUTPUT" || die "failed to save PR cache for branch ${CURRENT_BRANCH}"
fi
printf '%s\n' "$OUTPUT"
