#!/bin/bash
set -o pipefail
# git-ai - LLM-powered git workflow tools
# Usage: git-ai <commit|pr|providers|tiers> [...]

SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
# shellcheck source=lib/ai-common.sh
source "${SCRIPT_DIR}/../lib/ai-common.sh"

# ---------------------------------------------------------------------------
# PR cache helpers
# ---------------------------------------------------------------------------

current_branch_name() {
  local branch
  branch=$(git branch --show-current 2>/dev/null) || return 1
  [[ -n "$branch" ]] || return 1
  printf '%s\n' "$branch"
}

branch_cache_path() {
  local git_dir="$1"
  local branch_name="$2"
  local base_branch="$3"
  local cache_key

  cache_key=$(printf '%s\n%s\n' "$branch_name" "$base_branch" | git hash-object --stdin) || return 1
  printf '%s\n' "${git_dir}/pr-cache/${cache_key}/last-output"
}

load_cached_pr() {
  local git_dir="$1"
  local branch_name="$2"
  local base_branch="$3"
  local cache_file
  cache_file=$(branch_cache_path "$git_dir" "$branch_name" "$base_branch") || return 1
  [[ -r "$cache_file" ]] || return 1
  cat "$cache_file"
}

load_cached_pr_sha() {
  local git_dir="$1"
  local branch_name="$2"
  local base_branch="$3"
  local cache_file sha_file
  cache_file=$(branch_cache_path "$git_dir" "$branch_name" "$base_branch") || return 1
  sha_file="$(dirname "$cache_file")/last-head-sha"
  [[ -r "$sha_file" ]] || return 1
  cat "$sha_file"
}

save_cached_pr() {
  local git_dir="$1"
  local branch_name="$2"
  local base_branch="$3"
  local output="$4"
  local head_sha="${5:-}"
  local cache_file cache_dir

  cache_file=$(branch_cache_path "$git_dir" "$branch_name" "$base_branch") || return 1
  cache_dir=$(dirname "$cache_file")
  mkdir -p "$cache_dir" || return 1
  printf '%s\n' "$output" >"$cache_file"
  if [[ -n "$head_sha" ]]; then
    printf '%s\n' "$head_sha" >"${cache_dir}/last-head-sha"
  fi
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_commit() {
  local PROVIDER MODEL_TIER
  PROVIDER=${1:-$(get_last_provider commit)}
  MODEL_TIER="${2:-}"
  local PROMPT
  PROMPT=$(cat "${SCRIPT_DIR}/../python/git_ai/prompts/commit.txt") || die "failed to read commit prompt"

  git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"

  if [[ "$PROVIDER" == "last" ]]; then
    local GIT_DIR
    GIT_DIR=$(git rev-parse --git-dir)
    [[ -r "${GIT_DIR}/commit-last-message" ]] || die "no saved commit message"
    cat "${GIT_DIR}/commit-last-message"
    return 0
  fi

  git diff --staged --quiet && die "no staged changes to summarize"

  local STAGED_DIFF LAST_TAG COMMITS_SINCE RELEASE_CONTEXT INPUT generated
  STAGED_DIFF=$(git diff --staged) || die "failed to read staged diff"

  LAST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
  if [[ -n "$LAST_TAG" ]]; then
    COMMITS_SINCE=$(git rev-list --count "${LAST_TAG}..HEAD" 2>/dev/null || echo "?")
    RELEASE_CONTEXT="Release context: last tag ${LAST_TAG}, ${COMMITS_SINCE} commits since — staged changes are unreleased"
  else
    RELEASE_CONTEXT="Release context: no release tags found — treat all changes as unreleased"
  fi

  INPUT="<release_context>${RELEASE_CONTEXT}</release_context>"$'\n\n'"<diff>
${STAGED_DIFF}
</diff>"

  generated=$(run_provider commit "$PROVIDER" "$PROMPT" "$INPUT" "$MODEL_TIER") || exit $?
  save_last_message commit "$generated"
  printf '%s\n' "$generated"
}

cmd_pr() {
  local PROVIDER MODEL_TIER BASE FRESH
  PROVIDER=$(get_last_provider pr)
  MODEL_TIER=""
  BASE=""
  FRESH=false

  while [[ $# -gt 0 ]]; do
    case $1 in
      --base)
        BASE="$2"
        shift 2
        ;;
      --fresh)
        FRESH=true
        shift
        ;;
      claude|gemini|codex)
        PROVIDER="$1"
        shift
        case "${1:-}" in
          haiku|sonnet|opus|flash-lite|pro|mini|standard)
            MODEL_TIER="$1"
            shift
            ;;
        esac
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  local PROMPT_TWO_PASS PROMPT_FALLBACK PROMPT_TWO_PASS_UPDATE PROMPT_FALLBACK_UPDATE
  PROMPT_TWO_PASS=$(cat "${SCRIPT_DIR}/../python/git_ai/prompts/pr-two-pass.txt") || die "failed to read pr-two-pass prompt"
  PROMPT_FALLBACK=$(cat "${SCRIPT_DIR}/../python/git_ai/prompts/pr-fallback.txt") || die "failed to read pr-fallback prompt"
  PROMPT_TWO_PASS_UPDATE=$(cat "${SCRIPT_DIR}/../python/git_ai/prompts/pr-two-pass-update.txt") || die "failed to read pr-two-pass-update prompt"
  PROMPT_FALLBACK_UPDATE=$(cat "${SCRIPT_DIR}/../python/git_ai/prompts/pr-fallback-update.txt") || die "failed to read pr-fallback-update prompt"

  git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"
  local GIT_DIR
  GIT_DIR=$(git rev-parse --git-dir)

  local CURRENT_BRANCH=""
  if CURRENT_BRANCH=$(current_branch_name); then
    :
  fi

  if [[ -z "$BASE" ]]; then
    BASE=$(git remote show origin 2>/dev/null | sed -n 's/.*HEAD branch: //p')
    BASE=${BASE:-main}
  fi

  # Each commit prefixed with GITAI_COMMIT to distinguish subjects from body lines
  local LOG
  LOG=$(git log --format="GITAI_COMMIT %s%n%b" "$BASE"..HEAD 2>/dev/null) || die "failed to read commit log against $BASE"
  [[ -z "$LOG" ]] && die "no commits ahead of $BASE"

  # Count how many commits follow conventional commit format (subject lines only)
  local CONVENTIONAL_COUNT=0
  local TOTAL_COUNT=0
  while IFS= read -r line; do
    [[ "$line" == "GITAI_COMMIT "* ]] || continue
    local msg type
    msg="${line#GITAI_COMMIT }"
    type=$(printf '%s' "$msg" | sed 's/[!(].*//' | sed 's/:.*//')
    TOTAL_COUNT=$((TOTAL_COUNT + 1))
    case "$type" in
      feat|fix|refactor|docs|chore|ci|test|style|perf|build)
        CONVENTIONAL_COUNT=$((CONVENTIONAL_COUNT + 1)) ;;
    esac
  done <<< "$LOG"

  # Load cached PR and SHA if available (not --fresh)
  local EXISTING="" CACHED_SHA=""
  if [[ "$FRESH" != "true" && -n "$CURRENT_BRANCH" ]]; then
    EXISTING=$(load_cached_pr "$GIT_DIR" "$CURRENT_BRANCH" "$BASE" || true)
    CACHED_SHA=$(load_cached_pr_sha "$GIT_DIR" "$CURRENT_BRANCH" "$BASE" || true)
  fi

  # Use cached SHA as input base for incremental mode; falls back to BASE if SHA is
  # missing or no longer in repo (e.g. after rebase/force-push)
  local INPUT_BASE="$BASE"
  if [[ -n "$CACHED_SHA" ]] && git cat-file -e "${CACHED_SHA}^{commit}" 2>/dev/null; then
    INPUT_BASE="$CACHED_SHA"
  fi

  # Narrow LOG to new commits only when incremental (CONVENTIONAL_COUNT already from full log)
  if [[ "$INPUT_BASE" != "$BASE" ]]; then
    LOG=$(git log --format="GITAI_COMMIT %s%n%b" "${INPUT_BASE}..HEAD" 2>/dev/null) || LOG=""
  fi

  # No new commits since last generation — output cached PR directly, skip LLM call
  if [[ -n "$EXISTING" && -z "$LOG" && "$INPUT_BASE" != "$BASE" ]]; then
    echo "git-ai: no new commits since last generation, using cached output (use --fresh to regenerate)" >&2
    printf '%s\n' "$EXISTING"
    return 0
  fi

  # Three-dot merge-base diff for full range; two-dot exact range for incremental
  local DIFF_STAT
  if [[ "$INPUT_BASE" == "$BASE" ]]; then
    DIFF_STAT=$(git diff --stat "$BASE"...HEAD 2>/dev/null) || die "failed to read diff stat against $BASE"
  else
    DIFF_STAT=$(git diff --stat "${INPUT_BASE}..HEAD" 2>/dev/null) || die "failed to read diff stat since last generation"
  fi

  local PROMPT INPUT

  if (( TOTAL_COUNT > 0 && CONVENTIONAL_COUNT * 2 >= TOTAL_COUNT )); then
    # Two-pass: auto-draft from commit messages, LLM polishes (no diff sent)

    # Collect commits of a given type into a section; body lines indented under bullet
    draft_section() {
      local header="$1"
      local type="$2"
      local lines=""
      local capturing=false

      while IFS= read -r line; do
        if [[ "$line" == "GITAI_COMMIT "* ]]; then
          capturing=false
          local msg t desc
          msg="${line#GITAI_COMMIT }"
          t=$(printf '%s' "$msg" | sed 's/[!(].*//' | sed 's/:.*//')
          if [[ "$t" == "$type" ]]; then
            desc="${msg#*: }"
            lines+="- ${desc}"$'\n'
            capturing=true
          fi
        elif [[ "$capturing" == true && -n "$line" ]]; then
          lines+="  ${line}"$'\n'
        fi
      done <<< "$LOG"

      [[ -n "$lines" ]] && printf '### %s\n%s' "$header" "$lines"
    }

    local DRAFT_BODY=""
    local args header type section
    for args in "Features feat" "Bug Fixes fix" "Refactors refactor" "Docs docs" \
                "Chores chore" "Continuous Integration ci" "Tests test" \
                "Style style" "Performance perf" "Build build"; do
      header="${args% *}"
      type="${args##* }"
      section=$(draft_section "$header" "$type")
      [[ -n "$section" ]] && DRAFT_BODY+="${section}"$'\n\n'
    done

    PROMPT="$PROMPT_TWO_PASS"
    INPUT="<draft>
$DRAFT_BODY
</draft>
<changed_files>
$DIFF_STAT
</changed_files>"

  else
    # Fallback: commits don't consistently use conventional format — pass diff directly
    local DIFF
    if [[ "$INPUT_BASE" == "$BASE" ]]; then
      DIFF=$(git diff -U0 "$BASE"...HEAD 2>/dev/null) || die "failed to read diff against $BASE"
    else
      DIFF=$(git diff -U0 "${INPUT_BASE}..HEAD" 2>/dev/null) || die "failed to read diff since last generation"
    fi
    PROMPT="$PROMPT_FALLBACK"
    # Strip GITAI_COMMIT prefix so the LLM sees a clean commit log
    INPUT="<commit_log>
$(printf '%s\n' "$LOG" | sed 's/^GITAI_COMMIT //')
</commit_log>
<changed_files>
$DIFF_STAT
</changed_files>
<diff>
$DIFF
</diff>"
  fi

  if [[ -n "${EXISTING:-}" ]]; then
    echo "git-ai: updating existing PR draft for ${CURRENT_BRANCH} (use --fresh to regenerate)" >&2
    INPUT="<existing_pr>
${EXISTING}
</existing_pr>

${INPUT}"
    if (( TOTAL_COUNT > 0 && CONVENTIONAL_COUNT * 2 >= TOTAL_COUNT )); then
      PROMPT="$PROMPT_TWO_PASS_UPDATE"
    else
      PROMPT="$PROMPT_FALLBACK_UPDATE"
    fi
  fi

  local LAST_TAG COMMITS_SINCE RELEASE_CONTEXT SEMVER_CONTEXT
  LAST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
  if [[ -n "$LAST_TAG" ]]; then
    COMMITS_SINCE=$(git rev-list --count "${LAST_TAG}..HEAD" 2>/dev/null || echo "?")
    SEMVER_CONTEXT=""
    if [[ "$LAST_TAG" =~ ^v?([0-9]+)\.([0-9]+)\.([0-9]+) ]]; then
      local MAJOR="${BASH_REMATCH[1]}" MINOR="${BASH_REMATCH[2]}" PATCH="${BASH_REMATCH[3]}"
      SEMVER_CONTEXT=". Next release: breaking→v$((MAJOR+1)).0.0, feature→v${MAJOR}.$((MINOR+1)).0, fix→v${MAJOR}.${MINOR}.$((PATCH+1))"
    fi
    RELEASE_CONTEXT="Release context: current version ${LAST_TAG}, ${COMMITS_SINCE} commits since last release${SEMVER_CONTEXT}"
  else
    RELEASE_CONTEXT="Release context: no release tags found — treat all changes as unreleased"
  fi
  INPUT="<release_context>${RELEASE_CONTEXT}</release_context>"$'\n\n'"${INPUT}"

  local OUTPUT
  OUTPUT=$(run_provider pr "$PROVIDER" "$PROMPT" "$INPUT" "$MODEL_TIER") || exit $?
  save_last_message pr "$OUTPUT"
  local HEAD_SHA
  HEAD_SHA=$(git rev-parse HEAD 2>/dev/null) || HEAD_SHA=""
  if [[ -n "$CURRENT_BRANCH" ]]; then
    save_cached_pr "$GIT_DIR" "$CURRENT_BRANCH" "$BASE" "$OUTPUT" "$HEAD_SHA" ||
      die "failed to save PR cache for branch ${CURRENT_BRANCH} against ${BASE}"
  fi
  printf '%s\n' "$OUTPUT"
}

cmd_providers() {
  list_providers "${1:-commit}"
}

cmd_tiers() {
  list_tiers "${1:-}" "${2:-commit}"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  CMD="${1:-}"
  shift || true

  case "$CMD" in
    commit)    cmd_commit "$@" ;;
    pr|mr)     cmd_pr "$@" ;;
    providers) cmd_providers "$@" ;;
    tiers)     cmd_tiers "$@" ;;
    "")        die "usage: git-ai <commit|pr|providers|tiers> [...]" ;;
    *)         die "unknown command: $CMD" ;;
  esac
fi
